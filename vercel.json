{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install --include=optional && npm install lightningcss-linux-x64-gnu@1.32.0 @rollup/rollup-linux-x64-gnu@4.61.1 --no-save --no-package-lock",
  "framework": "vite",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
